APP_NAME=IMS
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_REAL_KEY
APP_DEBUG=false
APP_URL=https://api.paktradinggroup.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=REPLACE_WITH_DB_NAME
DB_USERNAME=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_DB_PASS

# ✅ PRODUCTION SESSION — must match frontend domain
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.paktradinggroup.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ✅ SANCTUM — Frontend domain must be listed here
SANCTUM_STATEFUL_DOMAINS=ims.paktradinggroup.com,paktradinggroup.com

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@paktradinggroup.com"
MAIL_FROM_NAME="IMS"
